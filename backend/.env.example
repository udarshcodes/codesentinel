# CodeSentinel Environment Configuration
# Copy this file to .env and fill in your actual values

# Groq API Keys (comma-separated for round-robin)
GROQ_API_KEY=gsk_your_key_1,gsk_your_key_2,gsk_your_key_3,gsk_your_key_4,gsk_your_key_5
GROQ_EMERGENCY_KEY=gsk_your_emergency_key
GROQ_TOKENS_PER_KEY=100000

# Admin Dashboard Secret
ADMIN_SECRET=change_me_to_a_strong_secret

# GitHub Personal Access Token (needs 'repo' scope)
GITHUB_TOKEN=ghp_your_github_token_here

# Storage paths
TEMP_REPO_PATH=/tmp/repos
CHROMA_PERSIST_PATH=./chroma_data

# CORS allowed origins (comma-separated, used by FastAPI)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Alert webhook URL for key exhaustion notifications
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
